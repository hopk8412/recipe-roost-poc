# Database
# For local dev, route the app through PgBouncer (transaction pooling, port 5433).
# prepare:false is already set in db/index.ts for PgBouncer compatibility.
DATABASE_URL="postgres://recipe_user:secret@localhost:5433/recipe_roost"

# Direct PostgreSQL connection — used by Drizzle migrations only (DDL is
# incompatible with PgBouncer transaction pooling).  Port 5434 because a local
# PostgreSQL install may already occupy 5432.
DATABASE_URL_DIRECT="postgres://recipe_user:secret@localhost:5434/recipe_roost"

# Redis (Docker)
REDIS_URL="redis://localhost:6379"

# MinIO — S3-compatible local file storage
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="recipe-roost"
# Browser-accessible base URL for MinIO (override when app runs in Docker)
MINIO_PUBLIC_URL="http://localhost:9000"

# SvelteKit origin (must match the URL your app is served from)
ORIGIN="http://localhost:5173"

# Better Auth — generate a strong random secret for production
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"
