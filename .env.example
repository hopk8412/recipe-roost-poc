# Database
# For local dev, Docker PostgreSQL runs on 5434 (5432 may be used by a local PG install)
DATABASE_URL="postgres://recipe_user:secret@localhost:5434/recipe_roost"

# Redis (Docker)
REDIS_URL="redis://localhost:6379"

# MinIO — S3-compatible local file storage
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="recipe-roost"

# SvelteKit origin (must match the URL your app is served from)
ORIGIN="http://localhost:5173"

# Better Auth — generate a strong random secret for production
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"
